{
  "apiVersion": "yggdrasil.io/v1alpha1",
  "kind": "integration_surface",
  "metadata": {
    "name": "surface-stripe",
    "namespace": "global",
    "integration_type": "stripe"
  },
  "spec": {
    "category": "integration",
    "owners": ["team:platform"],
    "runtime": {
      "kind": "spa",
      "exposure": "public",
      "base_path": "/s/stripe",
      "health_path": "/healthz",
      "image": "ghcr.io/dakasa-yggdrasil/surface-stripe"
    },
    "display": {
      "title": "Stripe",
      "subtitle": "Webhooks, saldo e conciliação",
      "icon": "stripe",
      "color_token": "brand.stripe",
      "appears_on": ["ops-integrations"]
    },
    "core_contracts": [
      "authorization",
      "integration_catalog",
      "external_identity",
      "workflow_runs",
      "action_catalog"
    ],
    "capabilities": [
      {
        "name": "integration-admin",
        "tabs": ["overview", "webhooks", "balance", "disputes", "reconciliation"]
      }
    ]
  }
}
